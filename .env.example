# =================== 数据库配置 ===================
POSTGRES_USER=aistock
POSTGRES_PASSWORD=aistock123
POSTGRES_DB=aistock
DATABASE_URL=postgresql+asyncpg://aistock:aistock123@localhost:5488/aistock

# =================== Redis 配置 ===================
REDIS_URL=redis://localhost:6388/0

# =================== Tushare 配置 ===================
TUSHARE_TOKEN=your_tushare_token_here

# =================== 轻舟账户配置 ===================
# 首次启动写入数据库的默认总资产（元）；之后在「账户管理」页维护
QINGZHOU_TOTAL_ASSET=1000000

# =================== 应用配置 ===================
APP_NAME=轻舟版交易系统
APP_VERSION=0.1.0
DEBUG=False
SECRET_KEY=your-secret-key-change-in-production

# =================== API 配置 ===================
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3088,http://localhost:8000

# =================== 企业微信机器人配置 ===================
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE
NOTIFY_ENABLED=False

# =================== LLM 配置 ===================
LLM_ENABLED=False
LLM_API_KEY=
LLM_MODEL=
